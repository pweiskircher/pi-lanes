{
  "name": "pi-lanes",
  "private": true,
  "version": "0.1.0",
  "description": "Lane-oriented workflow scaffolding for pi",
  "keywords": ["pi-package"],
  "pi": {
    "extensions": ["./extensions"],
    "skills": ["./skills"]
  },
  "type": "module",
  "bin": {
    "pi-lane": "./bin/pi-lane.mjs",
    "pi-lane-start": "./bin/pi-lane-start.mjs"
  },
  "scripts": {
    "check": "npm run typecheck && npm run test",
    "typecheck": "tsc --project tsconfig.json",
    "test": "node --import tsx --test test/**/*.test.ts",
    "dashboard:dev": "npm --prefix dashboard-app run dev",
    "dashboard:dev:full": "node scripts/dashboard-dev-full.mjs",
    "dashboard:build": "npm --prefix dashboard-app run build"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "commander": "^14.0.3"
  }
}
