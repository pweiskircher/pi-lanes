{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/lane-todos.schema.json",
  "title": "Lane TODO file",
  "type": "object",
  "additionalProperties": false,
  "required": ["laneId", "todos"],
  "properties": {
    "laneId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "todos": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/todo"
      }
    }
  },
  "$defs": {
    "todo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "priority",
        "createdBy",
        "needsReview",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^todo-[a-z0-9]+$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["proposed", "open", "in_progress", "blocked", "done", "dropped"]
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "createdBy": {
          "type": "string",
          "enum": ["human", "llm"]
        },
        "needsReview": {
          "type": "boolean"
        },
        "proposalReason": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "createdBy": {
                "const": "llm"
              }
            },
            "required": ["createdBy"]
          },
          "then": {
            "required": ["proposalReason"],
            "properties": {
              "status": {
                "const": "proposed"
              },
              "needsReview": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "createdBy": {
                "const": "human"
              }
            },
            "required": ["createdBy"]
          },
          "then": {
            "properties": {
              "needsReview": {
                "const": false
              }
            }
          }
        }
      ]
    }
  }
}
