{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/lane-runtime.schema.json",
  "title": "Lane runtime state",
  "type": "object",
  "additionalProperties": false,
  "required": ["laneId", "isActive", "updatedAt", "sessionName", "repoPath", "mode"],
  "properties": {
    "laneId": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "isActive": {"type": "boolean"},
    "startedAt": {"type": "string", "format": "date-time"},
    "updatedAt": {"type": "string", "format": "date-time"},
    "sessionName": {"type": "string", "minLength": 1},
    "sessionId": {"type": "string", "minLength": 1},
    "repoPath": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "enum": ["idle", "interactive", "working", "waiting_for_input", "blocked", "stopped"]},
    "messageBridge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["port", "authToken"],
      "properties": {
        "port": {"type": "integer", "minimum": 1, "maximum": 65535},
        "authToken": {"type": "string", "minLength": 1}
      }
    }
  }
}
